generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id @default(uuid())
  username String    @unique
  email    String    @unique
  password String
  contents Content[]
  links    Link[]
  shares   Share[]
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  contents Content[]
}

model Content {
  id      String   @id @default(uuid())
  title   String
  link    String
  type    String // "link", "video", "document", "tweet", "tag"
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  tags    Tag[]
}

model Link {
  id     String @id @default(uuid())
  link   String
  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Share {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  shareLink  String    @unique
  expiry     DateTime?
  isPublic   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Document {
  id        String         @id
  state     Bytes
  updatedAt DateTime       @updatedAt
  outgoing  DocumentLink[] @relation("FromDoc")
  incoming  DocumentLink[] @relation("ToDoc")
}

/**
 * Tracks wiki-style [[Document Title]] backlinks between documents.
 * Updated whenever the editor detects link changes in content.
 */
model DocumentLink {
  fromDocId  String
  toDocId    String
  fromDoc    Document @relation("FromDoc", fields: [fromDocId], references: [id], onDelete: Cascade)
  toDoc      Document @relation("ToDoc", fields: [toDocId], references: [id], onDelete: Cascade)

  @@id([fromDocId, toDocId])
  @@index([toDocId])
}
