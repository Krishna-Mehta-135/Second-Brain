{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "NODE_ENV",
        "API_URL",
        "API_BASE_URL",
        "NEXT_PUBLIC_API_BASE_URL",
        "DB_SSL_CA"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "**/*.tsbuildinfo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["API_URL", "API_BASE_URL", "NEXT_PUBLIC_API_BASE_URL"],
      "outputs": []
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build", "generate"],
      "outputs": []
    }
  }
}
