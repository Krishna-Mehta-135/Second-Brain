# Infrastructure
POSTGRES_USER=knowdex
POSTGRES_PASSWORD=knowdex
POSTGRES_DB=knowdex

# Ports
HTTP_PORT=8000
WS_PORT=8080

# Backend Config
JWT_SECRET=your_jwt_secret_here
REDIS_URL="redis://localhost:6379"
# GCP Memorystore: set REDIS_HOST to the private IP — takes priority over REDIS_URL
REDIS_HOST=
REDIS_PORT=6379
FRONTEND_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://knowdex:knowdex@localhost:5432/knowdex?schema=public"

# Frontend Config (baked into Next.js bundle at build time — update before docker build)
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000/api/v1"
NEXT_PUBLIC_WS_URL="ws://127.0.0.1:8080"

# AI
GEMINI_API_KEY="your_gemini_api_key_here"

# OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://127.0.0.1:8000/api/v1/auth/google/callback"

GH_CLIENT_ID="your_github_client_id"
GH_CLIENT_SECRET="your_github_client_secret"
GH_CALLBACK_URL="http://127.0.0.1:8000/api/v1/auth/github/callback"
