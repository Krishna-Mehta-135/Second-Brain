# Infrastructure
POSTGRES_USER=knowdex
POSTGRES_PASSWORD=knowdex
POSTGRES_DB=knowdex

# Ports
HTTP_PORT=8000
WS_PORT=8080

# Backend Config
JWT_SECRET=your_jwt_secret_here
REDIS_URL="redis://localhost:6379"
FRONTEND_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://knowdex:knowdex@localhost:5432/knowdex?schema=public"

# Frontend Config (baked into Next.js bundle at build time — update before docker build)
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
NEXT_PUBLIC_WS_URL="ws://localhost:8080"

# AI
GEMINI_API_KEY="your_gemini_api_key_here"
